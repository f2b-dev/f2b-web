# f2b-sandbox 上游（服务端 BFF，勿暴露管理密钥到浏览器）
F2B_SANDBOX_URL=http://127.0.0.1:13287

# f2b-tunnel 上游（预览 URL BFF /api/tunnels）
F2B_TUNNEL_URL=http://127.0.0.1:8790

# 产品 API：sandbox 开启 F2B_AUTH_MODE=api_key 时，BFF 用此密钥访问 /v1/sandboxes*
# 在 sandbox 侧用 admin 创建一把 sk_live_* 后写入本变量（仅服务端）
# F2B_SANDBOX_API_KEY=

# 管理 /api/keys → /v1/api-keys；与 sandbox 的 F2B_ADMIN_TOKEN 一致
# auth=off 时可不设
# F2B_SANDBOX_ADMIN_TOKEN=
