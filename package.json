{
  "name": "f2b-web",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --filter @f2b/web dev",
    "build": "pnpm --filter @f2b/web build",
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm --filter @f2b/web lint",
    "e2e:bff": "bash scripts/e2e-bff.sh",
    "ci:guards": "bash scripts/ci-guards.sh",
    "check:bff-map": "bash scripts/check-bff-map.sh",
    "audit:prod": "pnpm audit --prod --registry https://registry.npmjs.org"
  },
  "pnpm": {
    "overrides": {
      "sharp": ">=0.35.0",
      "postcss@<8.5.10": ">=8.5.10"
    }
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
